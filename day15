package springmvcpractices.com;

import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.RestController;
//create a using @RequestParam which is multiple Params
@RestController
public class GreetController {
    @GetMapping("/search")
    public String greet(@RequestParam String keyword,@RequestParam int page){
        return "Searching "+keyword+ "on page "+page;
    }
}
