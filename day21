package springmvcpractices.com;

import org.springframework.web.bind.annotation.*;

//Combining @PathVariable and @RequestParam
@RestController
public class ControllerUser {
    @GetMapping("/products/{id}")
    @ResponseBody
    public String getProduct(@PathVariable int id, @RequestParam (defaultValue = "USD") String currency){
       return "Product "+id+ "Priced in" +currency;
    }
}
